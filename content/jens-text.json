    {
      "zh": "我愛喝咖啡。",
      "pinyin": "Wǒ ài hē kāfēi.",
      "de": "I love drinking coffee."
    },
    {
      "zh": "我常去健身房。",
      "pinyin": "Wǒ cháng qù jiànshēnfáng.",
      "de": "I often go to the gym."
    }
