{
  "id": 2,
  "title": {
    "zh": "我的家人",
    "pinyin": "Wǒ de jiārén",
    "de": "My Family"
  },
  "objectives": [
    "Name family members",
    "Express possession with 的",
    "Use 有/沒有 for having / not having",
    "Learn the measure words 個 and 張"
  ],
  "dialogues": [
    {
      "id": "l2-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — My Family"
      },
      "lines": [
        {
          "speaker": "張怡君",
          "zh": "開文，你有兄弟姐妹嗎？",
          "pinyin": "Kāiwén, nǐ yǒu xiōngdì jiěmèi ma?",
          "de": "Kaiwen, do you have siblings?"
        },
        {
          "speaker": "王開文",
          "zh": "有，我有一個哥哥，兩個妹妹。",
          "pinyin": "Yǒu, wǒ yǒu yí ge gēge, liǎng ge mèimei.",
          "de": "Yes, I have one older brother and two younger sisters."
        },
        {
          "speaker": "張怡君",
          "zh": "你的家人都在美國嗎？",
          "pinyin": "Nǐ de jiārén dōu zài Měiguó ma?",
          "de": "Is your whole family in the USA?"
        },
        {
          "speaker": "王開文",
          "zh": "不是，我哥哥在美國，妹妹在臺灣。",
          "pinyin": "Bú shì, wǒ gēge zài Měiguó, mèimei zài Táiwān.",
          "de": "No, my brother is in the USA; my sisters are in Taiwan."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l2-d1-q1",
          "questionDe": "Does 王開文 have siblings?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l2-d1-q2",
          "questionDe": "How many sisters does 王開文 have?",
          "answerType": "text",
          "correctAnswer": "兩個",
          "acceptableAnswers": ["2", "zwei", "兩個", " zwei"]
        },
        {
          "id": "l2-d1-q3",
          "questionDe": "Where is his brother?",
          "answerType": "text",
          "correctAnswer": "美國",
          "acceptableAnswers": ["amerika", "usa", "美國"]
        }
      ]
    },
    {
      "id": "l2-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Phone Call"
      },
      "lines": [
        {
          "speaker": "王開文",
          "zh": "喂，請問你是李小姐嗎？",
          "pinyin": "Wéi, qǐngwèn nǐ shì Lǐ xiǎojiě ma?",
          "de": "Hello, are you Miss Li?"
        },
        {
          "speaker": "李明華",
          "zh": "是的，我是李明華。",
          "pinyin": "Shì de, wǒ shì Lǐ Mínghuá.",
          "de": "Yes, I am Li Minghua."
        },
        {
          "speaker": "王開文",
          "zh": "我有很多照片，你要不要看？",
          "pinyin": "Wǒ yǒu hěn duō zhàopiàn, nǐ yào bu yào kàn?",
          "de": "I have a lot of photos — would you like to see them?"
        },
        {
          "speaker": "李明華",
          "zh": "好啊！你的照片好看嗎？",
          "pinyin": "Hǎo a! Nǐ de zhàopiàn hǎokàn ma?",
          "de": "Sure! Are your photos nice?"
        },
        {
          "speaker": "王開文",
          "zh": "很好看！",
          "pinyin": "Hěn hǎokàn!",
          "de": "Very nice!"
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l2-d2-q1",
          "questionDe": "Who is 王開文 talking to on the phone?",
          "answerType": "text",
          "correctAnswer": "李明華",
          "acceptableAnswers": ["李明華", "li minghua", "李小姐"]
        },
        {
          "id": "l2-d2-q2",
          "questionDe": "Does 王開文 have photos?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l2-d2-q3",
          "questionDe": "How are the photos?",
          "answerType": "text",
          "correctAnswer": "很好看",
          "acceptableAnswers": ["很好看", "schön", "sehr schön", "gut"]
        }
      ]
    }
  ],
