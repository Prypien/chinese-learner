  "grammar": [
    {
      "id": "l2-g1",
      "title": { "zh": "的 — Besitz", "de": "Possession with 的" },
      "pattern": "Besitzer + 的 + Nomen",
      "explanationDe": "的 connects owner and possession. Example: 我的書 = my book.",
      "examples": [
        { "zh": "我的書", "pinyin": "Wǒ de shū", "de": "my book" },
        { "zh": "你的家人", "pinyin": "Nǐ de jiārén", "de": "your family" },
        { "zh": "李老師的名字", "pinyin": "Lǐ lǎoshī de míngzi", "de": "Teacher Li's name" }
      ],
      "exercises": [
        {
          "id": "l2-g1-e1",
          "type": "fill-blank",
          "promptDe": "Add the possessive particle:",
          "sentenceBefore": "我",
          "sentenceAfter": "書",
          "correctAnswer": "的"
        },
        {
          "id": "l2-g1-e2",
          "type": "fill-blank",
          "promptDe": "Complete:",
          "sentenceBefore": "你",
          "sentenceAfter": "家人",
          "correctAnswer": "的"
        }
      ]
    },
    {
      "id": "l2-g2",
      "title": { "zh": "有 / 沒有", "de": "Having and not having" },
      "pattern": "Subjekt + 有/沒有 + Objekt",
      "explanationDe": "有 means \"to have.\" The negative is always 沒有, not 不有.",
      "examples": [
        { "zh": "我有很多照片。", "pinyin": "Wǒ yǒu hěn duō zhàopiàn.", "de": "I have a lot of photos." },
        { "zh": "我沒有兄弟姐妹。", "pinyin": "Wǒ méiyǒu xiōngdì jiěmèi.", "de": "I don't have any siblings." }
      ],
      "exercises": [
        {
          "id": "l2-g2-e1",
          "type": "fill-blank",
          "promptDe": "Positive: I have a book.",
          "sentenceBefore": "我",
          "sentenceAfter": "書。",
          "correctAnswer": "有",
          "acceptableAnswers": ["有", "有一本", "有一"]
        },
        {
          "id": "l2-g2-e2",
          "type": "fill-blank",
          "promptDe": "Negative: I don't have siblings.",
          "sentenceBefore": "我",
          "sentenceAfter": "兄弟姐妹。",
          "correctAnswer": "沒有"
        }
      ]
    },
    {
      "id": "l2-g3",
      "title": { "zh": "都 — alle", "de": "都 for \"all\"" },
      "pattern": "Subjekt + 都 + Prädikat",
      "explanationDe": "都 means \"all\" or \"both\" and comes after the subject, before the verb.",
      "examples": [
        { "zh": "我的家人都在美國。", "pinyin": "Wǒ de jiārén dōu zài Měiguó.", "de": "My whole family is in the USA." },
        { "zh": "我們都姓陳。", "pinyin": "Wǒmen dōu xìng Chén.", "de": "We are all surnamed Chen." }
      ],
      "exercises": [
        {
