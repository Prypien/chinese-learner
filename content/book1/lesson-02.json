  "dialogues": [
    {
      "id": "l2-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — Meine Familie"
      },
      "lines": [
        {
          "speaker": "張怡君",
          "zh": "開文，你有兄弟姐妹嗎？",
          "pinyin": "Kāiwén, nǐ yǒu xiōngdì jiěmèi ma?",
          "de": "Kaiwen, hast du Geschwister?"
        },
        {
          "speaker": "王開文",
          "zh": "有，我有一個哥哥，兩個妹妹。",
          "pinyin": "Yǒu, wǒ yǒu yí ge gēge, liǎng ge mèimei.",
          "de": "Ja, ich habe einen älteren Bruder und zwei jüngere Schwestern."
        },
        {
          "speaker": "張怡君",
          "zh": "你的家人都在美國嗎？",
          "pinyin": "Nǐ de jiārén dōu zài Měiguó ma?",
          "de": "Ist deine ganze Familie in den USA?"
        },
        {
          "speaker": "王開文",
          "zh": "不是，我哥哥在美國，妹妹在臺灣。",
          "pinyin": "Bú shì, wǒ gēge zài Měiguó, mèimei zài Táiwān.",
          "de": "Nein, mein Bruder ist in den USA, meine Schwestern sind in Taiwan."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l2-d1-q1",
          "questionDe": "Hat 王開文 Geschwister?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l2-d1-q2",
          "questionDe": "Wie viele Schwestern hat 王開文?",
          "answerType": "text",
          "correctAnswer": "兩個",
          "acceptableAnswers": ["2", "zwei", "兩個", " zwei"]
        },
        {
          "id": "l2-d1-q3",
          "questionDe": "Wo ist sein Bruder?",
          "answerType": "text",
          "correctAnswer": "美國",
          "acceptableAnswers": ["amerika", "usa", "美國"]
        }
      ]
    },
    {
      "id": "l2-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Telefonat"
      },
      "lines": [
        {
          "speaker": "王開文",
          "zh": "喂，請問你是李小姐嗎？",
          "pinyin": "Wéi, qǐngwèn nǐ shì Lǐ xiǎojiě ma?",
          "de": "Hallo, sind Sie Fräulein Li?"
        },
        {
          "speaker": "李明華",
          "zh": "是的，我是李明華。",
          "pinyin": "Shì de, wǒ shì Lǐ Mínghuá.",
          "de": "Ja, ich bin Li Minghua."
        },
        {
          "speaker": "王開文",
          "zh": "我有很多照片，你要不要看？",
          "pinyin": "Wǒ yǒu hěn duō zhàopiàn, nǐ yào bu yào kàn?",
          "de": "Ich habe viele Fotos, möchtest du sie sehen?"
        },
        {
          "speaker": "李明華",
          "zh": "好啊！你的照片好看嗎？",
          "pinyin": "Hǎo a! Nǐ de zhàopiàn hǎokàn ma?",
          "de": "Gerne! Sind deine Fotos schön?"
        },
        {
          "speaker": "王開文",
          "zh": "很好看！",
          "pinyin": "Hěn hǎokàn!",
          "de": "Sehr schön!"
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l2-d2-q1",
          "questionDe": "Mit wem telefoniert 王開文?",
          "answerType": "text",
          "correctAnswer": "李明華",
          "acceptableAnswers": ["李明華", "li minghua", "李小姐"]
        },
        {
          "id": "l2-d2-q2",
          "questionDe": "Hat 王開文 Fotos?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l2-d2-q3",
          "questionDe": "Wie sind die Fotos?",
          "answerType": "text",
          "correctAnswer": "很好看",
          "acceptableAnswers": ["很好看", "schön", "sehr schön", "gut"]
        }
      ]
    }
  ],
