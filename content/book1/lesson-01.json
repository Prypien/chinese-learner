  "dialogues": [
    {
      "id": "l1-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — Am Flughafen"
      },
      "lines": [
        {
          "speaker": "王開文",
          "zh": "陳小姐，你好！歡迎你來臺灣！",
          "pinyin": "Chén xiǎojiě, nǐ hǎo! Huānyíng nǐ lái Táiwān!",
          "de": "Fräulein Chen, hallo! Willkommen in Taiwan!"
        },
        {
          "speaker": "陳月美",
          "zh": "謝謝！",
          "pinyin": "Xièxie!",
          "de": "Danke!"
        },
        {
          "speaker": "王開文",
          "zh": "你是越南人嗎？",
          "pinyin": "Nǐ shì Yuènán rén ma?",
          "de": "Bist du Vietnamesin?"
        },
        {
          "speaker": "陳月美",
          "zh": "是的，我是越南人。你呢？",
          "pinyin": "Shì de, wǒ shì Yuènán rén. Nǐ ne?",
          "de": "Ja, ich bin Vietnamesin. Und du?"
        },
        {
          "speaker": "王開文",
          "zh": "我是美國人。",
          "pinyin": "Wǒ shì Měiguó rén.",
          "de": "Ich bin Amerikaner."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l1-d1-q1",
          "questionDe": "Ist 陳月美 Vietnamesin?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l1-d1-q2",
          "questionDe": "Woher kommt 王開文?",
          "answerType": "text",
          "correctAnswer": "美國",
          "acceptableAnswers": ["amerika", "usa", "美國", "從美國"]
        },
        {
          "id": "l1-d1-q3",
          "questionDe": "Was bedeutet 你呢？",
          "answerType": "text",
          "correctAnswer": "und du",
          "acceptableAnswers": ["und du?", "und du", "was ist mit dir"]
        }
      ]
    },
    {
      "id": "l1-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Tee oder Kaffee?"
      },
      "lines": [
        {
          "speaker": "李明華",
          "zh": "田中先生，你要不要喝咖啡？",
          "pinyin": "Tiánzhōng xiānshēng, nǐ yào bu yào hē kāfēi?",
          "de": "Herr Tanaka, möchtest du Kaffee trinken?"
        },
        {
          "speaker": "田中誠一",
          "zh": "不要，謝謝。我想喝茶。",
          "pinyin": "Bú yào, xièxie. Wǒ xiǎng hē chá.",
          "de": "Nein danke. Ich möchte Tee trinken."
        },
        {
          "speaker": "李明華",
          "zh": "烏龍茶好不好？",
          "pinyin": "Wūlóng chá hǎo bù hǎo?",
          "de": "Wie wäre es mit Oolong-Tee?"
        },
        {
          "speaker": "田中誠一",
          "zh": "好啊！臺灣人喜不喜歡喝茶？",
          "pinyin": "Hǎo a! Táiwān rén xǐ bu xǐhuān hē chá?",
          "de": "Gerne! Trinken Taiwanese gerne Tee?"
        },
        {
          "speaker": "李明華",
          "zh": "喜歡，臺灣人很喜歡喝烏龍茶。",
          "pinyin": "Xǐhuān, Táiwān rén hěn xǐhuān hē wūlóng chá.",
          "de": "Ja, Taiwanese trinken sehr gerne Oolong-Tee."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l1-d2-q1",
          "questionDe": "Möchte 田中誠一 Kaffee trinken?",
          "answerType": "yesno",
          "correctAnswer": "nein"
        },
        {
          "id": "l1-d2-q2",
          "questionDe": "Was möchte 田中誠一 trinken?",
          "answerType": "text",
          "correctAnswer": "茶",
          "acceptableAnswers": ["tee", "茶", "烏龍茶", "oolong"]
        },
        {
          "id": "l1-d2-q3",
          "questionDe": "Trinken Taiwanese gerne Tee?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        }
      ]
    }
  ],
