  "grammar": [
    {
      "id": "l1-g1",
      "title": { "zh": "嗎 — Ja/Nein-Fragen", "de": "Questions with 嗎" },
      "pattern": "Aussage + 嗎？",
      "explanationDe": "Add 嗎 to the end of a statement to form a yes/no question. Word order stays the same.",
      "examples": [
        { "zh": "你是李小姐嗎？", "pinyin": "Nǐ shì Lǐ xiǎojiě ma?", "de": "Are you Miss Li?" },
        { "zh": "他是日本人嗎？", "pinyin": "Tā shì Rìběn rén ma?", "de": "Is he Japanese?" }
      ],
      "exercises": [
        {
          "id": "l1-g1-e1",
          "type": "fill-blank",
          "promptDe": "Insert the correct particle (yes/no question):",
          "sentenceBefore": "你好",
          "sentenceAfter": "？",
          "correctAnswer": "嗎",
          "hintDe": "Question particle for yes/no questions"
        },
        {
          "id": "l1-g1-e2",
          "type": "fill-blank",
          "promptDe": "Insert the correct particle:",
          "sentenceBefore": "你是越南人",
          "sentenceAfter": "？",
          "correctAnswer": "嗎"
        }
      ]
    },
    {
      "id": "l1-g2",
      "title": { "zh": "呢 — Und du?", "de": "Follow-up questions with 呢" },
      "pattern": "Aussage，Subject + 呢？",
      "explanationDe": "呢 is used for reciprocal questions: \"And you?\" / \"What about …?\"",
      "examples": [
        { "zh": "我很好，你呢？", "pinyin": "Wǒ hěn hǎo, nǐ ne?", "de": "I'm fine, and you?" },
        { "zh": "我是美國人，你呢？", "pinyin": "Wǒ shì Měiguó rén, nǐ ne?", "de": "I am American, and you?" }
      ],
      "exercises": [
        {
          "id": "l1-g2-e1",
          "type": "fill-blank",
          "promptDe": "Add the particle for \"and you?\":",
          "sentenceBefore": "我是越南人，你",
          "sentenceAfter": "？",
          "correctAnswer": "呢"
        },
        {
          "id": "l1-g2-e2",
          "type": "fill-blank",
          "promptDe": "Complete:",
          "sentenceBefore": "我很好，你",
          "sentenceAfter": "？",
          "correctAnswer": "呢"
        }
      ]
    },
    {
      "id": "l1-g3",
      "title": { "zh": "很 — Graduierung", "de": "很 before adjectives" },
      "pattern": "Subjekt + 很 + Adjektiv",
      "explanationDe": "很 comes before stative verbs/adjectives and often means \"very,\" but is also used without strong emphasis.",
      "examples": [
        { "zh": "我很好。", "pinyin": "Wǒ hěn hǎo.", "de": "I'm fine." },
        { "zh": "臺灣人很喜歡喝茶。", "pinyin": "Táiwān rén hěn xǐhuān hē chá.", "de": "Taiwanese people really like to drink tea." }
      ],
      "exercises": [
