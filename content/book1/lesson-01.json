    {
      "id": "l1-g4",
      "title": { "zh": "不 — Verneinung", "de": "Negation with 不" },
      "pattern": "Subjekt + 不 + Verb",
      "explanationDe": "不 comes before the verb to negate.",
      "examples": [
        { "zh": "我不喜歡咖啡。", "pinyin": "Wǒ bù xǐhuān kāfēi.", "de": "I don't like coffee." },
