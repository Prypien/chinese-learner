{
  "id": 1,
  "title": {
    "zh": "歡迎你來臺灣！",
    "pinyin": "Huānyíng nǐ lái Táiwān!",
    "de": "Welcome to Taiwan!"
  },
  "objectives": [
    "Introduce yourself and greet others",
    "Form yes/no questions with 嗎 and A-不-A",
    "Express origin and preferences",
    "Use polite expressions"
  ],
  "dialogues": [
    {
      "id": "l1-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — At the Airport"
      },
      "lines": [
        {
          "speaker": "王開文",
          "zh": "陳小姐，你好！歡迎你來臺灣！",
          "pinyin": "Chén xiǎojiě, nǐ hǎo! Huānyíng nǐ lái Táiwān!",
          "de": "Miss Chen, hello! Welcome to Taiwan!"
        },
        {
          "speaker": "陳月美",
          "zh": "謝謝！",
          "pinyin": "Xièxie!",
          "de": "Thank you!"
        },
        {
          "speaker": "王開文",
          "zh": "你是越南人嗎？",
          "pinyin": "Nǐ shì Yuènán rén ma?",
          "de": "Are you Vietnamese?"
        },
        {
          "speaker": "陳月美",
          "zh": "是的，我是越南人。你呢？",
          "pinyin": "Shì de, wǒ shì Yuènán rén. Nǐ ne?",
          "de": "Yes, I am Vietnamese. And you?"
        },
        {
          "speaker": "王開文",
          "zh": "我是美國人。",
          "pinyin": "Wǒ shì Měiguó rén.",
          "de": "I am American."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l1-d1-q1",
          "questionDe": "Is 陳月美 Vietnamese?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l1-d1-q2",
          "questionDe": "Where is 王開文 from?",
          "answerType": "text",
          "correctAnswer": "美國",
          "acceptableAnswers": ["amerika", "usa", "美國", "從美國"]
        },
        {
          "id": "l1-d1-q3",
          "questionDe": "What does 你呢？ mean?",
          "answerType": "text",
          "correctAnswer": "und du",
          "acceptableAnswers": ["und du?", "und du", "was ist mit dir"]
        }
      ]
    },
    {
      "id": "l1-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Tea or Coffee?"
      },
      "lines": [
        {
          "speaker": "李明華",
          "zh": "田中先生，你要不要喝咖啡？",
          "pinyin": "Tiánzhōng xiānshēng, nǐ yào bu yào hē kāfēi?",
          "de": "Mr. Tanaka, would you like to drink coffee?"
        },
        {
          "speaker": "田中誠一",
          "zh": "不要，謝謝。我想喝茶。",
          "pinyin": "Bú yào, xièxie. Wǒ xiǎng hē chá.",
          "de": "No thank you. I would like to drink tea."
        },
        {
          "speaker": "李明華",
          "zh": "烏龍茶好不好？",
          "pinyin": "Wūlóng chá hǎo bù hǎo?",
          "de": "How about oolong tea?"
        },
        {
          "speaker": "田中誠一",
          "zh": "好啊！臺灣人喜不喜歡喝茶？",
          "pinyin": "Hǎo a! Táiwān rén xǐ bu xǐhuān hē chá?",
          "de": "Sure! Do Taiwanese people like to drink tea?"
        },
        {
          "speaker": "李明華",
          "zh": "喜歡，臺灣人很喜歡喝烏龍茶。",
          "pinyin": "Xǐhuān, Táiwān rén hěn xǐhuān hē wūlóng chá.",
          "de": "Yes, Taiwanese people really like to drink oolong tea."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l1-d2-q1",
          "questionDe": "Does 田中誠一 want to drink coffee?",
          "answerType": "yesno",
          "correctAnswer": "nein"
        },
        {
          "id": "l1-d2-q2",
          "questionDe": "What does 田中誠一 want to drink?",
          "answerType": "text",
          "correctAnswer": "茶",
          "acceptableAnswers": ["tee", "茶", "烏龍茶", "oolong"]
        },
        {
          "id": "l1-d2-q3",
          "questionDe": "Do Taiwanese people like to drink tea?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        }
      ]
    }
  ],
