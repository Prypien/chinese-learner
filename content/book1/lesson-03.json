  "dialogues": [
    {
      "id": "l3-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — Wochenendpläne"
      },
      "lines": [
        {
          "speaker": "白如玉",
          "zh": "週末你想做什麼？",
          "pinyin": "Zhōumò nǐ xiǎng zuò shénme?",
          "de": "Was möchtest du am Wochenende machen?"
        },
        {
          "speaker": "王開文",
          "zh": "我想去看電影。你呢？",
          "pinyin": "Wǒ xiǎng qù kàn diànyǐng. Nǐ ne?",
          "de": "Ich möchte ins Kino gehen. Und du?"
        },
        {
          "speaker": "白如玉",
          "zh": "我想去打籃球。",
          "pinyin": "Wǒ xiǎng qù dǎ lánqiú.",
          "de": "Ich möchte Basketball spielen gehen."
        },
        {
          "speaker": "王開文",
          "zh": "我們一起去看電影吧！",
          "pinyin": "Wǒmen yìqǐ qù kàn diànyǐng ba!",
          "de": "Lass uns zusammen ins Kino gehen!"
        },
        {
          "speaker": "白如玉",
          "zh": "好啊！",
          "pinyin": "Hǎo a!",
          "de": "Gerne!"
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l3-d1-q1",
          "questionDe": "Was möchte 王開文 am Wochenende machen?",
          "answerType": "text",
          "correctAnswer": "看電影",
          "acceptableAnswers": ["ins kino", "film schauen", "看電影", "電影"]
        },
        {
          "id": "l3-d1-q2",
          "questionDe": "Was möchte 白如玉 machen?",
          "answerType": "text",
          "correctAnswer": "打籃球",
          "acceptableAnswers": ["basketball", "打籃球", "籃球"]
        },
        {
          "id": "l3-d1-q3",
          "questionDe": "Gehen sie am Ende ins Kino?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        }
      ]
    },
    {
      "id": "l3-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Sport und Musik"
      },
      "lines": [
        {
          "speaker": "陳月美",
          "zh": "你常打棒球嗎？",
          "pinyin": "Nǐ cháng dǎ bàngqiú ma?",
          "de": "Spielst du oft Baseball?"
        },
        {
          "speaker": "田中誠一",
          "zh": "不常，我比較喜歡游泳。",
          "pinyin": "Bù cháng, wǒ bǐjiào xǐhuān yóuyǒng.",
          "de": "Nicht oft, ich schwimme lieber."
        },
        {
          "speaker": "陳月美",
          "zh": "週末去游泳怎麼樣？",
          "pinyin": "Zhōumò qù yóuyǒng zěnmeyàng?",
          "de": "Wie wäre es am Wochenende schwimmen zu gehen?"
        },
        {
          "speaker": "田中誠一",
          "zh": "好啊！我也喜歡聽音樂。",
          "pinyin": "Hǎo a! Wǒ yě xǐhuān tīng yīnyuè.",
          "de": "Gerne! Ich höre auch gerne Musik."
        },
        {
          "speaker": "陳月美",
          "zh": "臺灣人也很喜歡運動。",
          "pinyin": "Táiwān rén yě hěn xǐhuān yùndòng.",
          "de": "Taiwanese treiben auch sehr gerne Sport."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l3-d2-q1",
          "questionDe": "Was mag 田中誠一 lieber als Baseball?",
          "answerType": "text",
          "correctAnswer": "游泳",
          "acceptableAnswers": ["schwimmen", "游泳"]
        },
        {
          "id": "l3-d2-q2",
          "questionDe": "Spielt 田中誠一 oft Baseball?",
          "answerType": "yesno",
          "correctAnswer": "nein"
        },
        {
          "id": "l3-d2-q3",
          "questionDe": "Was mag 田中誠一 auch?",
          "answerType": "text",
          "correctAnswer": "音樂",
          "acceptableAnswers": ["musik", "音樂", "聽音樂"]
        }
      ]
    }
  ],
