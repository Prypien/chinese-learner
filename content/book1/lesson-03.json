  "dialogues": [
    {
      "id": "l3-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — Weekend Plans"
      },
      "lines": [
        {
          "speaker": "白如玉",
          "zh": "週末你想做什麼？",
          "pinyin": "Zhōumò nǐ xiǎng zuò shénme?",
          "de": "What would you like to do this weekend?"
        },
        {
          "speaker": "王開文",
          "zh": "我想去看電影。你呢？",
          "pinyin": "Wǒ xiǎng qù kàn diànyǐng. Nǐ ne?",
          "de": "I'd like to go see a movie. And you?"
        },
        {
          "speaker": "白如玉",
          "zh": "我想去打籃球。",
          "pinyin": "Wǒ xiǎng qù dǎ lánqiú.",
          "de": "I'd like to go play basketball."
        },
        {
          "speaker": "王開文",
          "zh": "我們一起去看電影吧！",
          "pinyin": "Wǒmen yìqǐ qù kàn diànyǐng ba!",
          "de": "Let's go see a movie together!"
        },
        {
          "speaker": "白如玉",
          "zh": "好啊！",
          "pinyin": "Hǎo a!",
          "de": "Sure!"
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l3-d1-q1",
          "questionDe": "What does 王開文 want to do on the weekend?",
          "answerType": "text",
          "correctAnswer": "看電影",
          "acceptableAnswers": ["ins kino", "film schauen", "看電影", "電影"]
        },
        {
          "id": "l3-d1-q2",
          "questionDe": "What does 白如玉 want to do?",
          "answerType": "text",
          "correctAnswer": "打籃球",
          "acceptableAnswers": ["basketball", "打籃球", "籃球"]
        },
        {
          "id": "l3-d1-q3",
          "questionDe": "Do they end up going to the movies?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        }
      ]
    },
    {
      "id": "l3-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Sports and Music"
      },
      "lines": [
        {
          "speaker": "陳月美",
          "zh": "你常打棒球嗎？",
          "pinyin": "Nǐ cháng dǎ bàngqiú ma?",
          "de": "Do you often play baseball?"
        },
        {
          "speaker": "田中誠一",
          "zh": "不常，我比較喜歡游泳。",
          "pinyin": "Bù cháng, wǒ bǐjiào xǐhuān yóuyǒng.",
          "de": "Not often — I prefer swimming."
        },
        {
          "speaker": "陳月美",
          "zh": "週末去游泳怎麼樣？",
          "pinyin": "Zhōumò qù yóuyǒng zěnmeyàng?",
          "de": "How about going swimming this weekend?"
        },
        {
          "speaker": "田中誠一",
          "zh": "好啊！我也喜歡聽音樂。",
          "pinyin": "Hǎo a! Wǒ yě xǐhuān tīng yīnyuè.",
          "de": "Sure! I also like listening to music."
        },
        {
          "speaker": "陳月美",
          "zh": "臺灣人也很喜歡運動。",
          "pinyin": "Táiwān rén yě hěn xǐhuān yùndòng.",
          "de": "Taiwanese people also really like sports."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l3-d2-q1",
          "questionDe": "What does 田中誠一 prefer over baseball?",
          "answerType": "text",
          "correctAnswer": "游泳",
          "acceptableAnswers": ["schwimmen", "游泳"]
        },
        {
          "id": "l3-d2-q2",
          "questionDe": "Does 田中誠一 often play baseball?",
          "answerType": "yesno",
          "correctAnswer": "nein"
        },
        {
          "id": "l3-d2-q3",
          "questionDe": "What else does 田中誠一 like?",
          "answerType": "text",
          "correctAnswer": "音樂",
          "acceptableAnswers": ["musik", "音樂", "聽音樂"]
        }
      ]
    }
  ],
