{
  "id": 4,
  "title": {
    "zh": "請問一共多少錢？",
    "pinyin": "Qǐngwèn yīgòng duōshǎo qián?",
    "de": "Excuse me, how much is the total?"
  },
  "objectives": [
    "Ask and state prices",
    "Use measure words for money and objects",
    "Learn 百, 千, 萬 for numbers",
    "Apply 幫 and 能/不能"
  ],
  "dialogues": [
    {
      "id": "l4-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — At the Shop"
      },
      "lines": [
        {
          "speaker": "陳月美",
          "zh": "請問，這杯咖啡多少錢？",
          "pinyin": "Qǐngwèn, zhè bēi kāfēi duōshǎo qián?",
          "de": "Excuse me, how much is this cup of coffee?"
        },
        {
          "speaker": "老闆",
          "zh": "一杯咖啡八十塊錢。",
          "pinyin": "Yì bēi kāfēi bāshí kuài qián.",
          "de": "One cup of coffee is eighty NT dollars."
        },
        {
          "speaker": "陳月美",
          "zh": "我要兩杯，一共多少錢？",
          "pinyin": "Wǒ yào liǎng bēi, yīgòng duōshǎo qián?",
          "de": "I'd like two cups — how much is the total?"
        },
        {
          "speaker": "老闆",
          "zh": "一共一百六十塊錢。",
          "pinyin": "Yīgòng yībǎi liùshí kuài qián.",
          "de": "One hundred sixty NT dollars in total."
        },
        {
          "speaker": "陳月美",
          "zh": "好的，謝謝！",
          "pinyin": "Hǎo de, xièxie!",
          "de": "Okay, thank you!"
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l4-d1-q1",
          "questionDe": "How much does one cup of coffee cost?",
          "answerType": "text",
          "correctAnswer": "八十",
          "acceptableAnswers": ["80", "achtzig", "八十", "八十塊"]
        },
        {
          "id": "l4-d1-q2",
          "questionDe": "How many cups does 陳月美 want?",
          "answerType": "text",
          "correctAnswer": "兩杯",
          "acceptableAnswers": ["2", "zwei", "兩杯", "兩"]
        },
        {
          "id": "l4-d1-q3",
          "questionDe": "How much does everything cost together?",
          "answerType": "text",
          "correctAnswer": "一百六十",
          "acceptableAnswers": ["160", "einhundertsechzig", "一百六十", "一百六十塊"]
        }
      ]
    },
    {
      "id": "l4-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Buying a Cell Phone"
      },
      "lines": [
        {
          "speaker": "王開文",
          "zh": "這支手機多少錢？",
          "pinyin": "Zhè zhī shǒujī duōshǎo qián?",
          "de": "How much is this cell phone?"
        },
        {
          "speaker": "店員",
          "zh": "這支手機一萬塊錢。",
          "pinyin": "Zhè zhī shǒujī yí wàn kuài qián.",
          "de": "This cell phone costs ten thousand NT dollars."
        },
        {
          "speaker": "王開文",
          "zh": "新手機能上網嗎？",
          "pinyin": "Xīn shǒujī néng shàngwǎng ma?",
          "de": "Can the new phone go online?"
        },
        {
          "speaker": "店員",
          "zh": "當然能！請幫我包起來。",
          "pinyin": "Dāngrán néng! Qǐng bāng wǒ bāo qǐlái.",
          "de": "Of course! Please wrap it up for me."
        },
        {
          "speaker": "王開文",
          "zh": "好的，我要這支新的。",
          "pinyin": "Hǎo de, wǒ yào zhè zhī xīn de.",
          "de": "Okay, I'll take this new one."
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l4-d2-q1",
          "questionDe": "How much does the cell phone cost?",
          "answerType": "text",
          "correctAnswer": "一萬",
          "acceptableAnswers": ["10000", "zehntausend", "一萬", "一萬塊"]
        },
        {
          "id": "l4-d2-q2",
          "questionDe": "Can the new phone go online?",
          "answerType": "yesno",
          "correctAnswer": "ja"
        },
        {
          "id": "l4-d2-q3",
          "questionDe": "Which phone does 王開文 buy?",
          "answerType": "text",
          "correctAnswer": "新的",
          "acceptableAnswers": ["das neue", "新的", "新", "new"]
        }
      ]
    }
  ],
