  "dialogues": [
    {
      "id": "l4-d1",
      "title": {
        "zh": "對話一",
        "pinyin": "Duìhuà yī",
        "de": "Dialog I — Im Geschäft"
      },
      "lines": [
        {
          "speaker": "陳月美",
          "zh": "請問，這杯咖啡多少錢？",
          "pinyin": "Qǐngwèn, zhè bēi kāfēi duōshǎo qián?",
          "de": "Entschuldigung, wie viel kostet diese Tasse Kaffee?"
        },
        {
          "speaker": "老闆",
          "zh": "一杯咖啡八十塊錢。",
          "pinyin": "Yì bēi kāfēi bāshí kuài qián.",
          "de": "Eine Tasse Kaffee kostet achtzig Dollar."
        },
        {
          "speaker": "陳月美",
          "zh": "我要兩杯，一共多少錢？",
          "pinyin": "Wǒ yào liǎng bēi, yīgòng duōshǎo qián?",
          "de": "Ich möchte zwei Tassen, wie viel kostet das insgesamt?"
        },
        {
          "speaker": "老闆",
          "zh": "一共一百六十塊錢。",
          "pinyin": "Yīgòng yībǎi liùshí kuài qián.",
          "de": "Insgesamt einhundertsechzig Dollar."
        },
        {
          "speaker": "陳月美",
          "zh": "好的，謝謝！",
          "pinyin": "Hǎo de, xièxie!",
          "de": "Okay, danke!"
        }
      ],
      "comprehensionQuestions": [
        {
          "id": "l4-d1-q1",
          "questionDe": "Wie viel kostet eine Tasse Kaffee?",
          "answerType": "text",
          "correctAnswer": "八十",
          "acceptableAnswers": ["80", "achtzig", "八十", "八十塊"]
        },
        {
          "id": "l4-d1-q2",
          "questionDe": "Wie viele Tassen möchte 陳月美?",
          "answerType": "text",
          "correctAnswer": "兩杯",
          "acceptableAnswers": ["2", "zwei", "兩杯", "兩"]
        },
        {
          "id": "l4-d1-q3",
          "questionDe": "Wie viel kostet alles zusammen?",
          "answerType": "text",
          "correctAnswer": "一百六十",
          "acceptableAnswers": ["160", "einhundertsechzig", "一百六十", "一百六十塊"]
        }
      ]
    },
    {
      "id": "l4-d2",
      "title": {
        "zh": "對話二",
        "pinyin": "Duìhuà èr",
        "de": "Dialog II — Handys kaufen"
      },
      "lines": [
        {
          "speaker": "王開文",
          "zh": "這支手機多少錢？",
          "pinyin": "Zhè zhī shǒujī duōshǎo qián?",
          "de": "Wie viel kostet dieses Handy?"
        },
        {
          "speaker": "店員",
          "zh": "這支手機一萬塊錢。",
          "pinyin": "Zhè zhī shǒujī yí wàn kuài qián.",
          "de": "Dieses Handy kostet zehntausend Dollar."
        },
        {
          "speaker": "王開文",
          "zh": "新手機能上網嗎？",
          "pinyin": "Xīn shǒujī néng shàngwǎng ma?",
          "de": "Kann das neue Handy ins Internet?"
        },
        {
          "speaker": "店員",
          "zh": "當然能！請幫我包起來。",
          "pinyin": "Dāngrán néng! Qǐng bāng wǒ bāo qǐlái.",
          "de": "Natürlich! Bitte verpacken Sie es für mich."
        },
        {
          "speaker": "王開文",
          "zh": "好的，我要這支新的。",
          "pinyin": "Hǎo de, wǒ yào zhè zhī xīn de.",
          "de": "Okay, ich nehme dieses neue."
        }
      ],
      "comprehensionQuestions": [
        {
