    {
      "id": "l4-g4",
      "title": { "zh": "的 — Nomen weglassen", "de": "的 with omitted noun" },
      "pattern": "Adjektiv + 的",
      "explanationDe": "When the noun is clear from context, it can be omitted after 的: 我要新的 = I'll take the new one.",
