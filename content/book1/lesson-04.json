  "grammar": [
    {
      "id": "l4-g1",
      "title": { "zh": "量詞：塊、杯、支", "de": "Measure words for money and things" },
      "pattern": "Zahl + Zählwort + Nomen",
      "explanationDe": "塊 for money, 杯 for drinks, 支 for cell phones/pens. Structure: number + measure word + noun.",
      "examples": [
        { "zh": "八十塊錢", "pinyin": "Bāshí kuài qián", "de": "eighty NT dollars" },
        { "zh": "兩杯咖啡", "pinyin": "Liǎng bēi kāfēi", "de": "two cups of coffee" },
        { "zh": "這支手機", "pinyin": "Zhè zhī shǒujī", "de": "this cell phone" }
      ],
      "exercises": [
        {
          "id": "l4-g1-e1",
          "type": "fill-blank",
          "promptDe": "Measure word for coffee (cup):",
          "sentenceBefore": "一",
          "sentenceAfter": "咖啡",
          "correctAnswer": "杯"
        },
        {
          "id": "l4-g1-e2",
          "type": "fill-blank",
          "promptDe": "Measure word for money:",
          "sentenceBefore": "八十",
          "sentenceAfter": "錢",
          "correctAnswer": "塊"
        },
        {
          "id": "l4-g1-e3",
          "type": "fill-blank",
          "promptDe": "Measure word for cell phone:",
          "sentenceBefore": "這",
          "sentenceAfter": "手機",
          "correctAnswer": "支"
        }
      ]
    },
    {
      "id": "l4-g2",
      "title": { "zh": "幫 — für jemanden", "de": "幫 for \"do something for someone\"" },
      "pattern": "幫 + Person + Verb-Phrase",
      "explanationDe": "幫 indicates doing something for someone. 不 comes before 幫.",
      "examples": [
        { "zh": "請幫我包起來。", "pinyin": "Qǐng bāng wǒ bāo qǐlái.", "de": "Please wrap it up for me." },
        { "zh": "他不幫我買咖啡。", "pinyin": "Tā bù bāng wǒ mǎi kāfēi.", "de": "He doesn't buy coffee for me." }
      ],
      "exercises": [
        {
          "id": "l4-g2-e1",
          "type": "fill-blank",
          "promptDe": "Add \"for me\":",
          "sentenceBefore": "請",
          "sentenceAfter": "我包起來。",
          "correctAnswer": "幫"
        },
        {
          "id": "l4-g2-e2",
          "type": "fill-blank",
          "promptDe": "Negation (不 before 幫):",
          "sentenceBefore": "他不",
          "sentenceAfter": "我買咖啡。",
          "correctAnswer": "幫"
        }
      ]
    },
    {
      "id": "l4-g3",
      "title": { "zh": "能 / 不能", "de": "Ability with 能" },
      "pattern": "Subjekt + 能/不能 + Verb",
      "explanationDe": "能 expresses ability. Negation: 不能.",
      "examples": [
        { "zh": "新手機能上網。", "pinyin": "Xīn shǒujī néng shàngwǎng.", "de": "The new phone can go online." },
        { "zh": "我的手機不能照相。", "pinyin": "Wǒ de shǒujī bù néng zhàoxiàng.", "de": "My phone can't take photos." }
      ],
      "exercises": [
